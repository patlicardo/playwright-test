# Copy to .env.local and fill in (file is gitignored). Used by .vscode/launch.json for "Debug: xray-import-cucumber".
# Run `npm run test:cucumber` first so cucumber-report/cucumber.json exists, or set XRAY_CUCUMBER_JSON to a file path.
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
XRAY_TEST_EXEC_KEY=PT-2
# Test keys are inferred from feature filename pattern:
# features/{TEST_KEY}--{description}.feature  (example: features/PT-1--example-test.feature)
# XRAY_CUCUMBER_JSON=cucumber-report/cucumber.json
# XRAY_BASE_URL=https://xray.cloud.getxray.app
